{
  "name": "qualicharge-dataviz",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build:worker": "node scripts/build-worker.mjs",
    "build": "npm run build:worker && next build",
    "build:pages": "GITHUB_PAGES=true npm run build",
    "start": "npx serve@latest out -l 3000",
    "predev": "react-dsfr update-icons",
    "prebuild": "react-dsfr update-icons",
    "lint": "eslint",
    "typecheck": "tsc -p tsconfig.json && tsc -p src/workers/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@codegouvfr/react-dsfr": "^1.32.0",
    "hyparquet": "^1.25.5",
    "hyparquet-compressors": "^1.1.1",
    "leaflet": "^1.9.4",
    "leaflet-defaulticon-compatibility": "^0.1.2",
    "leaflet.heat": "^0.2.0",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "5.0.0-rc.2",
    "supercluster": "^8.0.1",
    "use-supercluster": "^1.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.heat": "^0.2.5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/supercluster": "^7.1.3",
    "esbuild": "^0.27.5",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "sass": "^1.98.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
