{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["esnext", "webworker"],
    "strict": true,
    "incremental": false,
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": false,
    "outDir": "../../public/worker",
    "rootDir": "../../src",
    "emitDeclarationOnly": false,
    "verbatimModuleSyntax": false,
    "baseUrl": "../../",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "files": ["./dataset-parser.worker.ts", "../types/irve-runtime.ts", "../types/irve.ts"],
  "exclude": []
}
